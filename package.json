{
  "name": "magicwindows",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Install Apple Magic Keyboard layouts on Windows — auto-detect your keyboard and fix keycap mismatches",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/build-detection-catalogue.mjs",
    "build": "vite build",
    "prebuild": "node scripts/build-detection-catalogue.mjs",
    "preview": "vite preview",
    "precheck": "node scripts/build-detection-catalogue.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "build:portable": "npm run tauri build && node scripts/build-portable.mjs",
    "measure": "node scripts/measure-bundle.mjs",
    "build:release": "npm run tauri build && node scripts/build-portable.mjs && node scripts/measure-bundle.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "archiver": "^7.0.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1"
  }
}
