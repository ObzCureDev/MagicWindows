{
  "id": "apple-de-qwertz",
  "name": {
    "en": "Apple German (QWERTZ)",
    "fr": "Apple Allemand (QWERTZ)"
  },
  "locale": "de-DE",
  "localeId": "00000407",
  "dllName": "kbdaplde",
  "description": {
    "en": "German QWERTZ layout matching Apple Magic Keyboard keycaps. Fixes the mismatch between Apple's key labels and Windows' default German layout, particularly the Option-layer characters like @, brackets, and braces.",
    "fr": "Disposition QWERTZ allemande correspondant aux inscriptions du Magic Keyboard Apple. Corrige le decalage entre les symboles imprimes sur les touches Apple et la disposition allemande par defaut de Windows."
  },
  "detectionKeys": [
    {
      "eventCode": "KeyQ",
      "prompt": {
        "en": "Press the Q key (top-left letter row)",
        "fr": "Appuyez sur la touche Q (rangee superieure, a gauche)"
      },
      "expectedBase": "q"
    },
    {
      "eventCode": "KeyZ",
      "prompt": {
        "en": "Press the key between T and U on the top row",
        "fr": "Appuyez sur la touche entre T et U sur la rangee superieure"
      },
      "expectedBase": "z"
    },
    {
      "eventCode": "KeyY",
      "prompt": {
        "en": "Press the key to the right of the left Shift (bottom-left area, second key)",
        "fr": "Appuyez sur la deuxieme touche a droite du Shift gauche (en bas a gauche)"
      },
      "expectedBase": "y"
    },
    {
      "eventCode": "BracketLeft",
      "prompt": {
        "en": "Press the key to the right of P",
        "fr": "Appuyez sur la touche a droite du P"
      },
      "expectedBase": "\u00fc"
    }
  ],
