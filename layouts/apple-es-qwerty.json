    "en": "ES MagicKeyboard",
    "fr": "ES MagicKeyboard"
  },
  "locale": "es-ES",
  "localeId": "00000c0a",
  "dllName": "kbdaples",
  "description": {
    "en": "Spanish QWERTY layout matching Apple Magic Keyboard keycaps. Fixes the mismatch between Apple's key labels and Windows' default Spanish layout.",
    "fr": "Disposition QWERTY espagnole correspondant aux inscriptions du Magic Keyboard Apple. Corrige le décalage entre les symboles imprimés sur les touches Apple et la disposition espagnole par défaut de Windows."
  },
  "detectionKeys": [
    {
      "eventCode": "Semicolon",
      "prompt": {
        "en": "Press the key to the right of L",
        "fr": "Appuyez sur la touche immédiatement à droite de L"
      },
      "expectedBase": "\u00f1"
    },
    {
      "eventCode": "Equal",
      "prompt": {
        "en": "Press the key to the right of the 0 (zero) key",
        "fr": "Appuyez sur la touche à droite du 0 (zéro)"
      },
      "expectedBase": "\u00a1"
    },
    {
      "eventCode": "Backquote",
      "prompt": {
        "en": "Press the key to the LEFT of the 1 key (top-left area)",
        "fr": "Appuyez sur la touche à GAUCHE du 1 (en haut à gauche)"
      },
      "expectedBase": "\u00ba"
    },
    {
      "eventCode": "Backslash",
      "prompt": {
        "en": "Press the key to the left of the Enter (Return) key",
        "fr": "Appuyez sur la touche à gauche de la touche Entrée"
      },
      "expectedBase": "\u00e7"
    }
  ],
