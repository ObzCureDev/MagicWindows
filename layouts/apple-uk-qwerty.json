{
  "id": "apple-uk-qwerty",
  "name": {
    "en": "Apple British (QWERTY)",
    "fr": "Apple Britannique (QWERTY)"
  },
  "locale": "en-GB",
  "localeId": "00000809",
  "dllName": "kbdapluk",
  "description": {
    "en": "British QWERTY layout matching Apple Magic Keyboard keycaps. Fixes the mismatch between Apple's key labels and Windows' default UK layout, particularly the repositioned grave, backslash, and section keys, plus the full Option-key layer with special characters and dead keys.",
    "fr": "Disposition QWERTY britannique correspondant aux inscriptions du Magic Keyboard Apple. Corrige le decalage entre les symboles imprimes sur les touches Apple et la disposition britannique par defaut de Windows, notamment les touches accent grave, barre oblique inverse et paragraphe, ainsi que la couche Option avec caracteres speciaux et touches mortes."
  },
  "detectionKeys": [
    {
      "eventCode": "Backquote",
      "prompt": {
        "en": "Press the key to the LEFT of the 1 key (top-left area)",
        "fr": "Appuyez sur la touche a GAUCHE du 1 (en haut a gauche)"
      },
      "expectedBase": "\u00a7"
    },
    {
      "eventCode": "IntlBackslash",
      "prompt": {
        "en": "Press the key between left Shift and Z",
        "fr": "Appuyez sur la touche entre Maj gauche et Z"
      },
      "expectedBase": "`"
    },
    {
      "eventCode": "Backslash",
      "prompt": {
        "en": "Press the key to the RIGHT of the single-quote key (left of Enter)",
        "fr": "Appuyez sur la touche a DROITE de l'apostrophe (a gauche de Entree)"
      },
      "expectedBase": "\\"
    }
  ],
